<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardCornerRadius="4dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/mediaThumbnail"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:scaleType="centerCrop"
            android:background="#EEEEEE"
            android:contentDescription="Gallery media thumbnail"/>

        <ImageView
            android:id="@+id/selectionOverlay"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="#88000000"
            android:visibility="gone"
            android:src="@drawable/ic_check_circle"
            android:padding="20dp"
            android:alpha="0.8"
            android:contentDescription="Selection overlay"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/mediaName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/mediaThumbnail"
            android:padding="4dp"
            android:singleLine="true"
            android:ellipsize="end"
            android:textColor="@android:color/black"
            android:textSize="12sp"
            android:text="Media Name"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>