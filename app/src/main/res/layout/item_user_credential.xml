<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:contentPadding="16dp"
    android:backgroundTint="@color/white_alice_blue">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_credential_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Name: John Doe"
            android:textColor="@color/text_primary_dark_blue"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tv_credential_username"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username: johndoe"
            android:textColor="@color/text_secondary_blue_grey"
            android:textSize="16sp"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_credential_password"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Password: ••••••••"
                android:textColor="@color/text_secondary_blue_grey"
                android:textSize="16sp"
                android:fontFamily="monospace"
                android:inputType="textPassword"/> <!-- This inputType is for visual hint, not functional -->

            <ImageView
                android:id="@+id/iv_toggle_password"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_visibility"
                android:contentDescription="Toggle password visibility"
                app:tint="@color/blue_medium"
                android:clickable="true"
                android:focusable="true"
                android:padding="2dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
