<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    tools:context=".settingsscreen.EditProfileActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_standard"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="?android:textColorPrimary"
        app:subtitleTextColor="?android:textColorSecondary"
        app:popupTheme="@style/Theme.Secura.PopupOverlay"
        app:layout_scrollFlags="scroll|enterAlways">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Edit Profile"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center_horizontal"/>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- Profile Picture with Edit Icon -->
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp">

                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profile_pic_image_view"
                    android:layout_width="160dp"
                    android:layout_height="160dp"
                    android:src="@drawable/ic_default_profile_pic"
                    app:civ_border_width="2dp"
                    app:civ_border_color="?attr/colorPrimary"
                    android:contentDescription="@string/profile_picture_description" />

                <ImageView
                    android:id="@+id/edit_profile_pic_icon"
                    android:layout_width="43dp"
                    android:layout_height="43dp"
                    android:layout_alignEnd="@id/profile_pic_image_view"
                    android:layout_alignBottom="@id/profile_pic_image_view"
                    android:layout_marginEnd="0dp"
                    android:layout_marginBottom="2dp"
                    android:background="@drawable/circle_background"
                    android:contentDescription="@string/edit_profile_picture_icon_description"
                    android:padding="8dp"
                    android:src="@drawable/ic_edit_pen"
                    app:tint="@color/white" />
            </RelativeLayout>

            <!-- Permission Switch -->
            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/permission_switch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Grant Required Permissions"
                android:textColor="?android:textColorPrimary"
                android:textSize="16sp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="24dp"
                app:thumbTint="?attr/colorPrimary"
                app:trackTint="?attr/colorSecondaryVariant"/>


            <!-- Name Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:hintTextColor="?attr/colorPrimary"
                app:boxStrokeColor="?attr/colorPrimary"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Name"
                    android:inputType="textPersonName"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorSecondary"
                    android:drawableEnd="@drawable/ic_edit_pen_small"
                    android:drawableTint="?android:textColorSecondary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Username Input -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="32dp"
                app:hintTextColor="?attr/colorPrimary"
                app:boxStrokeColor="?attr/colorPrimary"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp"
                style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_username"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Username"
                    android:inputType="textPersonName"
                    android:textColor="?android:textColorPrimary"
                    android:textColorHint="?android:textColorSecondary"
                    android:drawableEnd="@drawable/ic_edit_pen_small"
                    android:drawableTint="?android:textColorSecondary"/>
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Save Changes Button -->
            <Button
                android:id="@+id/btn_save_changes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Save Changes"
                style="@style/Widget.App.Button.Primary"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
