<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?android:colorBackground"
    tools:context=".settingsscreen.DatabaseDataActivity">

    <!-- Toolbar -->
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/blue_standard"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="?android:textColorPrimary"
        app:subtitleTextColor="?android:textColorSecondary"
        app:popupTheme="@style/Theme.Secura.PopupOverlay"
        app:layout_scrollFlags="scroll|enterAlways">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Database Data"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:fontFamily="sans-serif-medium"
            android:layout_gravity="center_horizontal"/>
    </androidx.appcompat.widget.Toolbar>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registered Account Data"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="@color/blue_dark"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp"/>

            <!-- RecyclerView to display user credentials -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view_credentials"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:nestedScrollingEnabled="false"
                tools:listitem="@layout/item_user_credential"/>

            <Button
                android:id="@+id/btn_edit_delete_credentials"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edit / Delete Credentials"
                style="@style/Widget.App.Button.Primary"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
