<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tvNoteTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_alignParentStart="true"
                android:layout_toStartOf="@id/btnDeleteNote"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="@color/text_primary_dark_blue"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="Note Title Goes Here" />

            <ImageButton
                android:id="@+id/btnDeleteNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Delete note"
                android:src="@android:drawable/ic_menu_delete"
                app:tint="@color/error_red" />

        </RelativeLayout>

        <TextView
            android:id="@+id/tvNoteTimestamp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textSize="12sp"
            android:textColor="@color/text_secondary_blue_grey"
            android:text="Jan 01, 2023 10:30 AM" />

        <TextView
            android:id="@+id/tvNoteContentPreview"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="@color/text_primary_dark_blue"
            android:maxLines="3"
            android:ellipsize="end"
            android:text="This is a preview of the note content. It can be quite long, so it will be truncated with an ellipsis if it exceeds three lines." />

    </LinearLayout>
</androidx.cardview.widget.CardView>