<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="@color/white_alice_blue">

    <ImageView
        android:id="@+id/lockIcon"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="48dp"
        android:src="@drawable/ic_lock"
        android:contentDescription="Lock Icon"
        app:tint="@color/blue_standard" />

    <TextView
        android:id="@+id/lockedAppText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Unlock [App Name]"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_dark_blue"
        android:layout_marginTop="16dp"
        android:gravity="center"/>

    <EditText
        android:id="@+id/pinInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:hint="Enter PIN"
        android:inputType="numberPassword"
        android:maxLength="4"
        android:gravity="center"
        android:background="@drawable/edit_text_background"
        android:padding="12dp"
        android:textColor="@color/text_primary_dark_blue"
        android:textColorHint="@color/text_secondary_blue_grey"
        android:textSize="19sp"
        android:focusable="false"
        android:cursorVisible="false"/>

    <GridLayout
        android:id="@+id/numpad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="4"
        android:layout_marginTop="24dp"
        android:layout_gravity="center_horizontal">

        <Button style="@style/NumpadButton" android:text="1"/>
        <Button style="@style/NumpadButton" android:text="2"/>
        <Button style="@style/NumpadButton" android:text="3"/>
        <Button style="@style/NumpadButton" android:text="4"/>
        <Button style="@style/NumpadButton" android:text="5"/>
        <Button style="@style/NumpadButton" android:text="6"/>
        <Button style="@style/NumpadButton" android:text="7"/>
        <Button style="@style/NumpadButton" android:text="8"/>
        <Button style="@style/NumpadButton" android:text="9"/>

        <Button style="@style/NumpadButton" android:text="0"/>
        <ImageButton
            android:id="@+id/clearButton"
            style="@style/NumpadImageButton"
            android:src="@drawable/ic_clear"/>
    </GridLayout>

    <Button
        android:id="@+id/unlockBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Unlock"
        style="@style/Widget.App.Button.Primary"/>
</LinearLayout>