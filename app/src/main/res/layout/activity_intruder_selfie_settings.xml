<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white_alice_blue"
    tools:context=".modulesscreen.privacyprotectors.intruderselfie.IntruderSelfieSettingsActivity">

    <!-- Toolbar for the activity -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbarIntruderSelfieSettings"
            style="@style/Widget.App.Toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/blue_standard"
            app:title="Intruder Selfie Settings"
            app:titleTextColor="@color/white"
            app:navigationIcon="@drawable/ic_arrow_back"/>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintTop_toBottomOf="@id/appBarLayout"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/enableIntruderSelfieSwitch"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant Required Permissions"
            android:textSize="18sp"
            android:textColor="@color/text_primary_dark_blue"
            android:layout_marginTop="16dp"
            android:checked="false"
            app:trackTint="@color/blue_light"
            app:thumbTint="@color/blue_standard"
            android:theme="@style/Theme.Secura" />

        <TextView
            android:id="@+id/intruderSelfieStatusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_blue_grey"
            android:text="Intruder Selfie: Disabled" />

        <Button
            android:id="@+id/viewIntruderSelfiePhotosButton"
            style="@style/Widget.App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="View Intruder Selfies"
            android:backgroundTint="@color/blue_standard"
            android:textColor="@color/white"
            android:enabled="false"/>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>