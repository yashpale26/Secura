<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:layout_marginBottom="8dp"
    android:background="@drawable/rounded_corners_background_light"> <TextView
    android:id="@+id/permissionName"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:text="android.permission.CAMERA"
    android:textStyle="bold"
    android:textSize="16sp"
    android:textColor="@color/text_primary_dark_blue"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="4dp">

        <TextView
            android:id="@+id/protectionLevel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Dangerous"
            android:textSize="14sp"
            android:textColor="@color/text_secondary_blue_grey"/>

        <TextView
            android:id="@+id/permissionStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Granted"
            android:gravity="end"
            android:textStyle="bold"
            android:textSize="14sp"
            android:textColor="@color/blue_dark"/>
    </LinearLayout>

    <TextView
        android:id="@+id/permissionDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Allows access to the camera device."
        android:textSize="13sp"
        android:textColor="@color/text_secondary_blue_grey"
        android:layout_marginTop="4dp"
        android:visibility="gone"/> </LinearLayout>